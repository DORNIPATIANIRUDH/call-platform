# ─────────────────────────────────────────────────────────────────
# Database (Neon or any Postgres)
# ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/callplatform

# ─────────────────────────────────────────────────────────────────
# Auth (NextAuth.js)
# ─────────────────────────────────────────────────────────────────
NEXTAUTH_SECRET=your-secret-here
NEXTAUTH_URL=http://localhost:3000

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# Magic link email (optional)
EMAIL_SERVER_HOST=
EMAIL_SERVER_PORT=587
EMAIL_SERVER_USER=
EMAIL_SERVER_PASSWORD=
EMAIL_FROM=

# ─────────────────────────────────────────────────────────────────
# AI — Transcription
# TRANSCRIPTION_PROVIDER=deepgram | whisper | aws
# ─────────────────────────────────────────────────────────────────
TRANSCRIPTION_PROVIDER=deepgram

DEEPGRAM_API_KEY=
OPENAI_API_KEY=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_TRANSCRIBE_BUCKET=

# ─────────────────────────────────────────────────────────────────
# AI — Analysis
# ANALYSIS_PROVIDER=anthropic | openai
# ─────────────────────────────────────────────────────────────────
ANALYSIS_PROVIDER=anthropic

ANTHROPIC_API_KEY=
# OPENAI_API_KEY= (reuse above)

# ─────────────────────────────────────────────────────────────────
# Storage (Supabase)
# ─────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=call-recordings

# ─────────────────────────────────────────────────────────────────
# Queue (Redis — Railway or Upstash)
# ─────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─────────────────────────────────────────────────────────────────
# Real-time (Pusher or self-hosted Soketi)
# ─────────────────────────────────────────────────────────────────
PUSHER_APP_ID=
PUSHER_KEY=
PUSHER_SECRET=
PUSHER_CLUSTER=us2
NEXT_PUBLIC_PUSHER_KEY=
NEXT_PUBLIC_PUSHER_CLUSTER=us2

# ─────────────────────────────────────────────────────────────────
# Billing (Stripe)
# ─────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

STRIPE_PRO_PRICE_ID=
STRIPE_ENTERPRISE_PRICE_ID=

# ─────────────────────────────────────────────────────────────────
# Integrations
# ─────────────────────────────────────────────────────────────────
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=
ZOOM_WEBHOOK_SECRET=

SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=

HUBSPOT_CLIENT_ID=
HUBSPOT_CLIENT_SECRET=

SALESFORCE_CLIENT_ID=
SALESFORCE_CLIENT_SECRET=
SALESFORCE_INSTANCE_URL=https://yourorg.salesforce.com

# ─────────────────────────────────────────────────────────────────
# Bot service (internal secret between web → bot)
# ─────────────────────────────────────────────────────────────────
BOT_WORKER_URL=http://localhost:3002
BOT_SECRET=internal-secret

# ─────────────────────────────────────────────────────────────────
# Email notifications (Resend)
# ─────────────────────────────────────────────────────────────────
RESEND_API_KEY=
EMAIL_FROM_NAME=CallPlatform
EMAIL_FROM_ADDRESS=notifications@yourcallplatform.com

# ─────────────────────────────────────────────────────────────────
# App
# ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
APP_ENV=development
